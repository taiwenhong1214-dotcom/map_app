<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- Search Bar (Visible by default) -->
    <TextView
        android:id="@+id/widget_search"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/widget_search_hint"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:textSize="14sp"
        android:textColor="#BBBBBB"
        android:background="@drawable/search_bg" />

    <!-- Live Tracking Banner (Gone by default) -->
    <LinearLayout
        android:id="@+id/widget_tracking_banner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@drawable/tracking_bg"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="18sp" />
        <TextView
            android:id="@+id/widget_tracking_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_tracking_default"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 3 Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Join Room -->
        <LinearLayout
            android:id="@+id/btn_join_room"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@drawable/icon_bg"
                android:text="🚪"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_btn_join_room"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Social / Community -->
        <LinearLayout
            android:id="@+id/btn_community"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@drawable/icon_bg"
                android:text="🌍"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_btn_community"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Album -->
        <LinearLayout
            android:id="@+id/btn_album"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@drawable/icon_bg"
                android:text="📸"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_btn_album"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
